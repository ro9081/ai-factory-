# ─────────────────────────────────────────────────────────────
# AI Factory — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── LLM Provider (Groq) ───────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# Groq model options:
#   llama-3.3-70b-versatile   ← recommended (best quality)
#   llama3-70b-8192           ← fast alternative
#   mixtral-8x7b-32768        ← great for structured reasoning
#   gemma2-9b-it              ← lightweight / free tier
LLM_MODEL=llama-3.3-70b-versatile

# Sampling temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.4

# ── Database ──────────────────────────────────────────────────
# Path to the SQLite database file (relative to project root)
DATABASE_URL=sqlite+aiosqlite:///./aifactory.db

# ── Backend ───────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
